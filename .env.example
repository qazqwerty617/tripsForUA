# Server Configuration
PORT=5051
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/tripsforua
# For production use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/tripsforua

# JWT Authentication  
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=30d

# Admin Credentials (for seeding)
Ayf vj,bj
ADMIN_NAME=Ілля Криворучка

# Frontend URL
FRONTEND_URL=http://localhost:5173
# For production:
# FRONTEND_URL=https://your-domain.com

# CORS Origins (comma separated for production)
# CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# File Upload
MAX_FILE_SIZE=10485760

# ==========================================
# NVIDIA NIM API — Free AI models
# Get your free key at: https://build.nvidia.com/models
# Free tier: 1000 credits/month (~1000 text requests OR ~50 image generations)
# ==========================================
# For TEXT: meta/llama-3.3-70b-instruct (descriptions, titles)
# For IMAGES: stabilityai/stable-diffusion-xl (no stripes, real quality!)
VITE_NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Add this to client/.env.local for frontend access:
# VITE_NVIDIA_API_KEY=nvapi-xxxx
