{
  "name": "trips-for-ua",
  "version": "1.0.0",
  "description": "Tour booking website with admin panel",
  "main": "server_go/main.go",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server_go && go run .",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "build:seo": "node client/scripts/get-routes.js && cd client && npm run build",
    "build:client": "cd client && npm install && npm run build",
    "build:all": "npm install && cd server_go && go build && cd ../client && npm install && npm run build",
    "start": "cd server_go && go run .",
    "start:prod": "cd server_go && go run .",
    "seed": "node server_node_backup/seed.js",
    "seed:aviatury": "node server_node_backup/seedAviatury.js"
  },
  "keywords": [
    "tours",
    "travel",
    "booking"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.0.1",
    "geoip-lite": "^1.4.10",
    "helmet": "^7.2.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}
